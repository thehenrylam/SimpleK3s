#!/bin/bash
set -euo pipefail

# Get a helpful message on any error
trap 'rc=$?; echo "ERROR: cloud-init failed at line $LINENO (exit $rc)"; exit $rc' ERR

# set up cloud init log
LOG_FILE="/var/log/simplek3s-cloudinit.log"
mkdir -p "$(dirname "$LOG_FILE")"
touch "$LOG_FILE"
chmod 0644 "$LOG_FILE"

# Send all output (stdout+stderr) to:
#  - your log file
#  - cloud-init output log (via console)
#  - syslog (tagged)
exec > >(awk '{ print strftime("[%Y-%m-%d %H:%M:%S]"), $0 }' \
    | tee -a "$LOG_FILE" \
    | logger -t simplek3s-cloudinit) 2>&1
echo "=== SimpleK3s cloud-init starting ==="
echo "User: $(id)"
echo "Hostname: $(hostname)"
echo "Date: $(date -Is)"

echo "Set up packages (apt-get)"
# update package manager
apt-get update -y
# install essentials
apt-get install -y awscli ca-certificates gettext-base
# install nice-to-haves
apt-get install -y fastfetch htop

# Install SSM agent (not pre-installed on Debian AMIs)
echo "Install SSM agent"
ARCH=$(dpkg --print-architecture) # amd64 or arm64
SSM_DEB="/tmp/amazon-ssm-agent.deb"
curl -fsSo "$SSM_DEB" "https://s3.amazonaws.com/ec2-downloads-windows/SSMAgent/latest/debian_$ARCH/amazon-ssm-agent.deb"
dpkg -i "$SSM_DEB"
systemctl enable amazon-ssm-agent
systemctl start amazon-ssm-agent
rm -f "$SSM_DEB"

# Configure SSM sessions to use bash instead of the default sh
mkdir -p /etc/amazon/ssm
cat > /etc/amazon/ssm/session-manager-agent.json <<'EOF'
{
    "shell": "/bin/bash"
}
EOF

COUNT_INDEX="${count_index}"
CLUSTER_TYPE="${cluster_type}" # controlplane / agentplane

BOOTSTRAP_BUCKET="${bootstrap_bucket}"
BOOTSTRAP_DIR="${bootstrap_dir}" # /opt/simplek3s/

echo "Initialize directory: $BOOTSTRAP_DIR"
mkdir -p $BOOTSTRAP_DIR
cd $BOOTSTRAP_DIR

function s3_sync_boostrap() {
    # Download everything from the S3 bucket into the bootstrap directory
    aws s3 sync "s3://$BOOTSTRAP_BUCKET/" "$BOOTSTRAP_DIR/" --only-show-errors
}

echo "Download S3 objects (default)"
s3_sync_boostrap

# Enable execution rights to *.sh scripts
echo "Enable execution rights to *.sh scripts"
find $BOOTSTRAP_DIR/ -type f -name "*.sh" -exec chmod u+x {} \; 

# Execute installation script
echo "Execute installation script"
"$BOOTSTRAP_DIR/${s3key_install_script}" "$COUNT_INDEX" "$CLUSTER_TYPE"
