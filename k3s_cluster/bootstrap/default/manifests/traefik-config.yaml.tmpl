# Force nodePort to be set to a static values (easier to expose ports to the outside world)  
apiVersion: helm.cattle.io/v1
kind: HelmChartConfig
metadata:
  name: traefik
  namespace: kube-system
spec:
  valuesContent: |-
    ports:
      web:
        nodePort: ${nodeport_http}
      websecure:
        nodePort: ${nodeport_https}

    # HA: run multiple Traefik replicas
    deployment:
      replicas: ${replica_count}
      podDisruptionBudget:
        enabled: true
        minAvailable: 1

    # Resource sizing (baseline)
    resources:
      requests:
        cpu: ${req_cpu}
        memory: ${req_mem}
      limits:
        cpu: ${lmt_cpu}
        memory: ${lmt_mem}
