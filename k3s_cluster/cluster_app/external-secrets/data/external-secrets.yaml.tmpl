apiVersion: v1
kind: Namespace
metadata:
  name: external-secrets

---
apiVersion: helm.cattle.io/v1
kind: HelmChart
metadata:
  name: external-secrets
  namespace: kube-system
spec:
  repo: https://charts.external-secrets.io
  chart: external-secrets
  targetNamespace: external-secrets
  createNamespace: true
  valuesContent: |-
    installCRDs: true

    # HA: multiple replicas require leader election to avoid double-reconciling
    replicaCount: ${resources.generic.replicas.target}
    leaderElect: true

    # Allow safe voluntary evictions (descheduler/drain)
    podDisruptionBudget:
      enabled: true
      minAvailable: ${resources.generic.replicas.minimum}

    # Prefer spreading across nodes (soft)
    topologySpreadConstraints:
      - maxSkew: 1
        topologyKey: kubernetes.io/hostname
        whenUnsatisfiable: ScheduleAnyway
        matchLabelKeys:
          - pod-template-hash

    # Resource sizing (baseline)
    resources:
      requests:
        cpu: ${resources.generic.req.cpu}
        memory: ${resources.generic.req.mem}
      limits:
        cpu: ${resources.generic.lmt.cpu}
        memory: ${resources.generic.lmt.mem}

    webhook:
      replicaCount: ${resources.webhook.replicas.target}
      podDisruptionBudget:
        enabled: true
        minAvailable: ${resources.webhook.replicas.minimum}
      resources:
        requests:
          cpu: ${resources.webhook.req.cpu}
          memory: ${resources.webhook.req.mem}
        limits:
          cpu: ${resources.webhook.lmt.cpu}
          memory: ${resources.webhook.lmt.mem}

    certController:
      replicaCount: ${resources.certController.replicas.target}
      podDisruptionBudget:
        enabled: true
        minAvailable: ${resources.certController.replicas.minimum}
      resources:
        requests:
          cpu: ${resources.certController.req.cpu}
          memory: ${resources.certController.req.mem}
        limits:
          cpu: ${resources.certController.lmt.cpu}
          memory: ${resources.certController.lmt.mem}
