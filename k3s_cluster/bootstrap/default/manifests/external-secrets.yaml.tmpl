apiVersion: v1
kind: Namespace
metadata:
  name: external-secrets

---
apiVersion: helm.cattle.io/v1
kind: HelmChart
metadata:
  name: external-secrets
  namespace: kube-system
spec:
  repo: https://charts.external-secrets.io
  chart: external-secrets
  targetNamespace: external-secrets
  createNamespace: true
  valuesContent: |-
    installCRDs: true

    # HA: multiple replicas require leader election to avoid double-reconciling
    replicaCount: ${replica_count}
    leaderElect: true

    # Allow safe voluntary evictions (descheduler/drain)
    podDisruptionBudget:
      enabled: true
      minAvailable: 1

    # Prefer spreading across nodes (soft)
    topologySpreadConstraints:
      - maxSkew: 1
        topologyKey: kubernetes.io/hostname
        whenUnsatisfiable: ScheduleAnyway
        matchLabelKeys:
          - pod-template-hash

    # Resource sizing (baseline)
    resources:
      requests:
        cpu: ${generic.req_cpu}
        memory: ${generic.req_mem}
      limits:
        cpu: ${generic.lmt_cpu}
        memory: ${generic.lmt_mem}

    webhook:
      replicaCount: ${replica_count}
      podDisruptionBudget:
        enabled: true
        minAvailable: 1
      resources:
        requests:
          cpu: ${webhook.req_cpu}
          memory: ${webhook.req_mem}
        limits:
          cpu: ${webhook.lmt_cpu}
          memory: ${webhook.lmt_mem}

    certController:
      replicaCount: ${replica_count}
      podDisruptionBudget:
        enabled: true
        minAvailable: 1
      resources:
        requests:
          cpu: ${certcontroller.req_cpu}
          memory: ${certcontroller.req_mem}
        limits:
          cpu: ${certcontroller.lmt_cpu}
          memory: ${certcontroller.lmt_mem}
