# DEFAULT ADD-ON: Kyverno
# Helps centralize Kubernetes rules + defaults in one place
apiVersion: helm.cattle.io/v1
kind: HelmChart
metadata:
  name: kyverno
  namespace: kube-system
spec:
  repo: https://kyverno.github.io/kyverno/
  chart: kyverno
  version: "${kyverno_chart_version}"   # e.g. "3.7.1"
  targetNamespace: kyverno
  createNamespace: true

  # This affects the helm-install-* Job pod
  tolerations:
    - key: "node-role.kubernetes.io/control-plane"
      operator: "Equal"
      value: "true"
      effect: "NoSchedule"

  valuesContent: |-
    # Keep it light for hobbyist clusters
    replicaCount: ${kyverno_replica_count}
%{ if kyverno_schedule_on_control_plane }
    tolerations:
      - key: "node-role.kubernetes.io/control-plane"
        operator: "Equal"
        value: "true"
        effect: "NoSchedule"

    affinity:
      nodeAffinity:
        preferredDuringSchedulingIgnoredDuringExecution:
          - weight: 100
            preference:
              matchExpressions:
                - key: node-role.kubernetes.io/control-plane
                  operator: Exists
%{ endif }
    resources:
      requests:
        cpu: ${kyverno_cpu_request}
        memory: ${kyverno_mem_request}
      limits:
        cpu: ${kyverno_cpu_limit}
        memory: ${kyverno_mem_limit}
